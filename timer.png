<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>テキストカウンター</title>

  <style>
    * {
      box-sizing: border-box;
    }

    body {
      font-family: sans-serif;
      background: #f5f5f5;
      margin: 0;
      height: 100vh;

      /* 完全中央寄せ */
      display: flex;
      justify-content: center;
      align-items: center;
    }

    /*余白のルール*/
    .container > * {
        margin-bottom: 12px;
    }
    .container > *:last-child {
    margin-bottom: 0;
    }

    .container {
      width: 420px;
      background: #fff;
      padding: 20px;
      border-radius: 12px;
      box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    textarea {
      width: 100%;
      height: 150px;
      resize: none;
      padding: 10px;
      font-size: 14px;
      border-radius: 8px;
      border: 1px solid #ccc;
    }

    .info {
      margin-top: 10px;
      display: flex;
      justify-content: space-between;
      font-size: 14px;
    }

    .limit {
      color: red;
      font-weight: bold;
    }

    .setting {
      margin-top: 10px;
      display: flex;
      gap: 10px;
      align-items: center;
      font-size: 14px;
    }

    input[type="number"] {
      width: 100px;
      padding: 5px;
    }
  </style>
</head>
<body>

<div class="container">
  <h2>テキストカウンター</h2>

  <!-- 最大文字数設定 -->
  <div class="setting">
    <label>最大文字数：</label>
    <input type="number" id="maxLengthInput" value="200" min="1">
  </div>

  <textarea id="textInput" placeholder="ここに入力..."></textarea>

  <div class="info">
    <span id="charCount">文字数：0</span>
    <span id="lineCount">行数：0</span>
  </div>

  <div class="info">
    <span id="limitStatus">残り：200文字</span>
  </div>
</div>

<script>
  // 要素の取得
  const textarea = document.getElementById("textInput");
  const charCount = document.getElementById("charCount");
  const lineCount = document.getElementById("lineCount");
  const limitStatus = document.getElementById("limitStatus");
  const maxLengthInput = document.getElementById("maxLengthInput");


  // カウント処理をまとめた関数
  function updateCount() {

    // 現在入力されているテキストを取得
    const text = textarea.value;

    // 最大文字数を取得（未入力や不正値の場合は0になる）
    const maxLength = parseInt(maxLengthInput.value) || 0;


    // 文字数を取得（改行や空白も含む）
    const length = text.length;

    // 文字数表示を更新
    charCount.textContent = "文字数：" + length;


    // 行数をカウント（空の場合は0行、それ以外は改行で分割）
    const lines = text === "" ? 0 : text.split("\n").length;

    // 行数表示を更新
    lineCount.textContent = "行数：" + lines;


    // 残り文字数を計算
    const remaining = maxLength - length;

    // 残り文字数表示を更新
    limitStatus.textContent = "残り：" + remaining + "文字";


    // 制限を超えた場合はクラスを付与して赤表示
    if (remaining < 0) {
      limitStatus.classList.add("limit");
    } else {
      // 制限内ならクラスを外す
      limitStatus.classList.remove("limit");
    }
  }


  // テキスト入力時にリアルタイムでカウント更新
  textarea.addEventListener("input", updateCount);

  // 最大文字数変更時にもカウント更新
  maxLengthInput.addEventListener("input", updateCount);


  // ページ読み込み時に初期状態を反映
  updateCount();
</script>

</body>
</html>